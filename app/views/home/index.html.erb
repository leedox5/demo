<div class="min-h-screen p-12 flex flex-col">
  <div>
    <h1>Hello, Rails + Hotwire!!</h1>
    <p class="text-base">
      This page is rendered through Rails layout.
      UA: <%= request.user_agent %>
    </p>

    <%= render partial: "message", locals: {
      message: "처음 표시된 메시지입니다."
    } %>

    <div class="flex justify-end mt-2">
      <%= link_to "메시지 바꾸기",
          home_message_path,
          data: { turbo_frame: "message_box" },
          class: "inline-flex rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
    </div>

    <div class="mt-8 rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
      <h2 class="mb-3 text-lg font-semibold">페이지 이동 테스트</h2>
      <p class="mb-4 text-sm text-gray-600">앱으로 접근했을 때 다른 페이지로 이동하는 링크입니다.</p>
      <div class="flex flex-col gap-2 sm:flex-row">
        <%= link_to "CSS 페이지로 이동",
            css_path,
            class: "inline-flex items-center justify-center rounded-md bg-slate-800 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-900" %>
        <%= link_to "홈으로 다시 이동",
            root_path,
            class: "inline-flex items-center justify-center rounded-md border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:border-slate-300 hover:bg-slate-50" %>
      </div>
    </div>
  </div>
</div>
