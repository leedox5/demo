<div class="min-h-screen bg-slate-50 py-6">
  <div class="mx-auto max-w-6xl px-4">
    <section class="rounded-[1.5rem] bg-white p-6 shadow-sm ring-1 ring-slate-200">
      <div class="grid gap-6 lg:grid-cols-[1.3fr_1fr] lg:items-center">
        <div class="space-y-6">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-blue-600">학습 기록 시작하기</p>
          <div class="space-y-4">
            <h1 class="text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl">나만의 단어/용어장을 빠르게 만들어보세요</h1>
            <p class="text-base leading-7 text-slate-600">단어/용어를 저장하고, 그룹으로 정리하며, 메모와 댓글로 이어가는 MVP 흐름을 바로 사용해보세요.</p>
          </div>
          <div class="flex flex-wrap gap-3">
            <%= link_to "항목 목록 보기", posts_path, class: "inline-flex items-center rounded-full bg-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-500" %>
            <%= link_to "새 항목 추가", new_post_path, class: "inline-flex items-center rounded-full border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" %>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-[1.5rem] bg-slate-50 p-4 shadow-sm ring-1 ring-slate-200">
            <p class="text-sm font-semibold text-slate-500">핵심 기능</p>
            <p class="mt-2 text-lg font-semibold text-slate-900">항목, 그룹, 댓글</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">단어장형 MVP를 바로 사용해보세요.</p>
          </div>
          <div class="rounded-[1.5rem] bg-slate-50 p-4 shadow-sm ring-1 ring-slate-200">
            <p class="text-sm font-semibold text-slate-500">다음 확장</p>
            <p class="mt-2 text-lg font-semibold text-slate-900">검색, 공유, 반복 학습</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">서비스 성장에 맞춰 기능을 더할 수 있습니다.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-8">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-2xl font-semibold text-slate-900">최근 학습 항목</h2>
          <p class="mt-1 text-sm text-slate-500">최근 저장한 단어와 용어를 확인하세요.</p>
        </div>
        <%= link_to "전체 보기", posts_path, class: "text-sm font-semibold text-blue-600 hover:text-blue-500" %>
      </div>

      <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        <% if @recent_posts.any? %>
          <% @recent_posts.each do |post| %>
            <div class="rounded-[1.5rem] border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
              <%= link_to post_path(post), class: "block text-lg font-semibold text-slate-900 hover:text-blue-600" do %>
                <%= truncate(post.title, length: 50) %>
              <% end %>
              <p class="mt-2 text-sm text-slate-500"><%= post.user.email %> · 댓글 <%= post.comments.count %></p>
              <p class="mt-3 text-sm leading-6 text-slate-600"><%= truncate(post.body, length: 90) %></p>
            </div>
          <% end %>
        <% else %>
          <div class="rounded-[1.5rem] border border-dashed border-slate-300 bg-white p-6 text-center text-slate-500">
            아직 저장된 항목이 없습니다.<br>
            <%= link_to "첫 항목을 추가해보세요", new_post_path, class: "text-blue-600 hover:text-blue-500" %>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</div>
