<div id="<%= dom_id post %>" class="w-full sm:w-auto my-5 space-y-5 rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
  <div>
    <strong class="block font-medium mb-1">Title:</strong>
    <%= post.title %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Body:</strong>
    <%= post.body %>
  </div>
  <div class="grid gap-2 sm:grid-cols-2 text-sm text-gray-500">
    <div><strong>User:</strong> <%= post.user.email %></div>
    <div><strong>Published:</strong> <%= l(post.created_at, format: :short) %></div>
  </div>
</div>
