<% content_for :title, "항목 목록" %>
<% content_for :main_top_padding, "pt-0" %>
<% content_for :main_x_padding, "px-2" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="mb-6 flex items-center justify-between gap-3 pt-3">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">단어·표현 노트</h1>
    </div>
    <%= link_to new_post_path, class: "inline-flex h-10 w-10 items-center justify-center rounded-md bg-blue-600 text-white hover:bg-blue-500", aria: { label: "새 항목 추가" }, title: "새 항목 추가" do %>
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v14M5 12h14" />
      </svg>
    <% end %>
  </div>

  <div class="mb-6 rounded-2xl border border-gray-200 bg-white p-3 shadow-sm">
    <%= form_with url: posts_path, method: :get, class: "flex items-center gap-2" do |form| %>
      <%= form.text_field :query, value: params[:query], placeholder: "검색어 입력", class: "min-w-0 flex-1 rounded-md border border-gray-300 px-2.5 py-2 text-sm" %>
      <%= form.select :group_id, options_from_collection_for_select(@groups, :id, :name, params[:group_id]), { include_blank: "전체 그룹" }, class: "w-28 rounded-md border border-gray-300 px-2.5 py-2 text-sm sm:w-40" %>
      <%= form.submit "검색", class: "rounded-md bg-blue-600 px-3.5 py-2 text-sm text-white" %>
    <% end %>
  </div>

  <div id="posts" class="space-y-4">
    <% if @posts.any? %>
      <% @posts.each do |post| %>
        <div class="rounded-2xl border border-gray-200 bg-white px-5 py-4 shadow-sm transition hover:shadow-md">
          <h2 class="text-lg font-semibold text-gray-900 leading-tight">
            <%= link_to post.title, post_path(post), class: "hover:text-blue-600" %>
          </h2>
          <div class="mt-3 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2 text-sm text-gray-500">
            <div class="min-w-0 text-left">
              <span class="font-medium text-gray-700"><%= post.user.display_name %></span>
              <% if post.group.present? %>
                <span class="ml-2 rounded-full bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700"><%= post.group.name %></span>
              <% end %>
            </div>
            <div class="flex flex-wrap justify-start sm:justify-end items-center gap-2 text-sm text-gray-500">
              <span>조회: <%= post.views_count_for_display %></span>
              <span class="text-slate-300">•</span>
              <span>댓글: <%= post.comments.count %></span>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center py-10 text-gray-500">등록된 항목이 없습니다.</p>
    <% end %>
  </div>
</div>
