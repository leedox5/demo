<% content_for :title, "표현 목록" %>
<% content_for :main_top_padding, "pt-4 sm:pt-5" %>
<% content_for :main_x_padding, "px-0 sm:px-6" %>

<% selected_post = @posts.first %>
<% total_comments = selected_post ? @posts.sum { |post| post.comments.count } : 0 %>

<div class="overflow-hidden rounded-none border-y border-[color:var(--nd-line)] bg-[color:var(--nd-bg)] sm:rounded-xl sm:border">
  <div class="grid min-h-[70vh] lg:grid-cols-[14rem_1fr] xl:grid-cols-[14rem_1fr_20rem]">
    <aside class="hidden bg-[color:var(--nd-sidebar)] p-6 lg:flex lg:flex-col lg:gap-7">
      <div>
        <%= link_to "NoteDox", root_path, class: "nd-heading text-3xl font-semibold text-[color:var(--nd-ink)]" %>
        <p class="mt-1 text-xs text-[color:var(--nd-muted)]">Leedox notes archive</p>
      </div>

      <nav class="space-y-2 text-sm">
        <%= link_to posts_path, class: "flex items-center gap-3 rounded-lg bg-[color:var(--nd-accent)] px-3 py-2.5 font-semibold text-white" do %>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.75v10.5M6.75 7.5h7.5a3 3 0 013 3v7.5h-7.5a3 3 0 01-3-3v-7.5z" />
          </svg>
          모든 표현
        <% end %>

        <%= link_to posts_path(query: params[:query], group_id: params[:group_id]), class: "flex items-center gap-3 rounded-lg px-3 py-2.5 text-[color:var(--nd-ink)] hover:bg-[color:var(--nd-surface)]" do %>
          <svg class="h-4 w-4 text-[color:var(--nd-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h8M8 14h5m-7.5 6.25h13A1.75 1.75 0 0020.25 18.5v-13A1.75 1.75 0 0018.5 3.75h-13A1.75 1.75 0 003.75 5.5v13A1.75 1.75 0 005.5 20.25z" />
          </svg>
          최근 memo
        <% end %>

        <%= link_to groups_path, class: "flex items-center gap-3 rounded-lg px-3 py-2.5 text-[color:var(--nd-ink)] hover:bg-[color:var(--nd-surface)]" do %>
          <svg class="h-4 w-4 text-[color:var(--nd-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.75 6.75h6.75l1.5 1.5h8.25v9a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6.75z" />
          </svg>
          그룹
        <% end %>
      </nav>

      <section class="space-y-3">
        <div class="flex items-center justify-between">
          <p class="text-xs font-bold uppercase tracking-[0.16em] text-[color:var(--nd-muted)]">Groups</p>
          <% if user_signed_in? %>
            <%= link_to new_group_path, class: "text-[color:var(--nd-muted)] hover:text-[color:var(--nd-accent)]", aria: { label: "그룹 추가" }, title: "그룹 추가" do %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v14M5 12h14" />
              </svg>
            <% end %>
          <% end %>
        </div>

        <div class="space-y-2">
          <%= link_to posts_path(query: params[:query]), class: "flex items-center gap-3 rounded-md py-1.5 text-sm text-[color:var(--nd-ink)] hover:text-[color:var(--nd-accent)]" do %>
            <span class="h-2 w-2 rounded-full <%= params[:group_id].blank? ? "bg-[color:var(--nd-accent)]" : "bg-[color:var(--nd-line)]" %>"></span>
            <span>전체 그룹</span>
          <% end %>

          <% @groups.limit(4).each do |group| %>
            <%= link_to posts_path(group_id: group.id, query: params[:query]), class: "flex items-center gap-3 rounded-md py-1.5 text-sm text-[color:var(--nd-ink)] hover:text-[color:var(--nd-accent)]" do %>
              <span class="h-2 w-2 rounded-full <%= params[:group_id].to_s == group.id.to_s ? "bg-[color:var(--nd-accent)]" : "bg-[color:var(--nd-line)]" %>"></span>
              <span><%= group.name %></span>
            <% end %>
          <% end %>
        </div>
      </section>

      <div class="mt-auto rounded-lg bg-[color:var(--nd-surface)]/70 p-4">
        <p class="text-xs font-bold uppercase tracking-[0.14em] text-[color:var(--nd-muted)]">Today</p>
        <p class="mt-2 nd-heading text-lg leading-tight text-[color:var(--nd-ink)]">낯선 표현을 오래 남기는 가장 좋은 방법은, 내 문장으로 다시 적어보는 것.</p>
      </div>
    </aside>

    <section class="bg-[color:var(--nd-surface)] p-5 sm:p-6 lg:p-8">
      <% if notice.present? %>
        <p class="mb-5 inline-block rounded-md bg-green-50 px-3 py-2 font-medium text-green-500" id="notice"><%= notice %></p>
      <% end %>

      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.16em] text-[color:var(--nd-muted)]">NoteDox</p>
          <h1 class="nd-heading text-4xl font-semibold text-[color:var(--nd-ink)]">Notes archive</h1>
          <p class="mt-1 text-sm text-[color:var(--nd-muted)]">오늘 만난 단어, 표현, 예문을 저장하고 memo로 이어서 학습해요.</p>
        </div>

        <%= link_to new_post_path, class: "inline-flex h-10 w-fit items-center gap-2 rounded-md bg-[color:var(--nd-accent)] px-4 text-sm font-bold text-white hover:bg-[color:var(--nd-accent-strong)]" do %>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v14M5 12h14" />
          </svg>
          새 표현
        <% end %>
      </div>

      <div class="mt-6 rounded-lg border border-[color:var(--nd-line)] bg-[color:var(--nd-surface)] p-3">
        <%= form_with url: posts_path, method: :get, class: "flex flex-col gap-2 sm:flex-row sm:items-center" do |form| %>
          <div class="flex min-w-0 flex-1 items-center gap-2 rounded-md border border-[color:var(--nd-line)] bg-[#F7F8F4] px-3 py-2">
            <svg class="h-4 w-4 text-[color:var(--nd-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35m1.6-5.4a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <%= form.text_field :query, value: params[:query], placeholder: "표현 또는 memo 검색", class: "min-w-0 flex-1 bg-transparent text-sm text-[color:var(--nd-ink)] outline-none placeholder:text-[color:var(--nd-muted)]" %>
          </div>

          <%= form.select :group_id, options_from_collection_for_select(@groups, :id, :name, params[:group_id]), { include_blank: "전체 그룹" }, class: "rounded-md border border-[color:var(--nd-line)] bg-[color:var(--nd-surface)] px-3 py-2 text-sm text-[color:var(--nd-ink)] outline-none focus:ring-2 focus:ring-[color:var(--nd-accent)] sm:w-40" %>
          <%= form.submit "검색", class: "rounded-md bg-[color:var(--nd-accent)] px-4 py-2 text-sm font-bold text-white hover:bg-[color:var(--nd-accent-strong)]" %>
        <% end %>
      </div>

      <div class="mt-6 grid gap-3 sm:grid-cols-3">
        <div class="rounded-lg border border-[color:var(--nd-line)] bg-green-50 px-4 py-3">
          <p class="text-xs font-bold uppercase tracking-[0.14em] text-[color:var(--nd-muted)]">Expressions</p>
          <p class="mt-1 nd-heading text-3xl font-semibold text-[color:var(--nd-ink)]"><%= @posts.size %></p>
        </div>
        <div class="rounded-lg border border-[color:var(--nd-line)] bg-[#F1F5EC] px-4 py-3">
          <p class="text-xs font-bold uppercase tracking-[0.14em] text-[color:var(--nd-muted)]">Memos</p>
          <p class="mt-1 nd-heading text-3xl font-semibold text-[color:var(--nd-ink)]"><%= total_comments %></p>
        </div>
        <div class="rounded-lg border border-[color:var(--nd-line)] bg-[#F2E4C8] px-4 py-3">
          <p class="text-xs font-bold uppercase tracking-[0.14em] text-[color:var(--nd-muted)]">Groups</p>
          <p class="mt-1 nd-heading text-3xl font-semibold text-[color:var(--nd-ink)]"><%= @groups.size %></p>
        </div>
      </div>

      <div id="posts" class="mt-6 space-y-3">
        <% if @posts.any? %>
          <div class="flex items-center justify-between text-xs font-bold uppercase tracking-[0.14em] text-[color:var(--nd-muted)]">
            <span>표현 목록</span>
            <span><%= @posts.size %>개 표현</span>
          </div>

          <% @posts.each do |post| %>
            <article class="rounded-lg border <%= post == selected_post ? "border-[color:var(--nd-accent)] bg-[#F7FBF2]" : "border-[color:var(--nd-line)] bg-white" %> px-5 py-4 transition hover:border-[color:var(--nd-accent)]/50">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                <div class="min-w-0">
                  <h2 class="nd-heading text-2xl font-semibold leading-tight text-[color:var(--nd-ink)]">
                    <%= link_to post.title, post_path(post), class: "hover:text-[color:var(--nd-accent)]" %>
                  </h2>
                  <p class="mt-2 line-clamp-2 text-sm leading-6 text-[color:var(--nd-muted)]"><%= truncate(post.body.to_s, length: 120) %></p>
                </div>

                <%= link_to edit_post_path(post), class: "inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-md border border-[color:var(--nd-line)] bg-[color:var(--nd-surface)] text-[color:var(--nd-muted)] hover:bg-[color:var(--nd-sidebar)] hover:text-[color:var(--nd-accent)]", aria: { label: "표현 수정" }, title: "표현 수정" do %>
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4h2m-7 14h12M6 18l-1 3 3-1 8-8-2-2-8 8z" />
                  </svg>
                <% end %>
              </div>

              <div class="mt-3 flex flex-col gap-2 text-sm text-[color:var(--nd-muted)] sm:flex-row sm:items-center sm:justify-between">
                <div class="min-w-0 text-left">
                  <span class="font-medium text-[color:var(--nd-ink)]"><%= post.user.display_name %></span>
                  <% if post.group.present? %>
                    <span class="ml-2 rounded-full bg-[color:var(--nd-sidebar)] px-2 py-1 text-xs font-medium text-[color:var(--nd-accent)]"><%= post.group.name %></span>
                  <% end %>
                </div>
                <div class="flex flex-wrap items-center justify-start gap-2 sm:justify-end">
                  <span>조회: <%= post.views_count_for_display %></span>
                  <span class="text-[color:var(--nd-line)]">•</span>
                  <span>memo: <%= post.comments.count %></span>
                  <span class="text-[color:var(--nd-line)]">•</span>
                  <span><%= l(post.created_at, format: :short) %></span>
                </div>
              </div>
            </article>
          <% end %>
        <% else %>
          <div class="rounded-lg border border-dashed border-[color:var(--nd-line)] bg-white px-6 py-10 text-center">
            <p class="nd-heading text-2xl font-semibold text-[color:var(--nd-ink)]">아직 등록된 표현이 없습니다.</p>
            <p class="mt-2 text-sm text-[color:var(--nd-muted)]">새 표현 버튼으로 첫 단어와 기억 단서를 남겨보세요.</p>
          </div>
        <% end %>
      </div>
    </section>

    <aside class="border-t border-[color:var(--nd-line)] bg-[#FBF8ED] p-5 sm:p-6 xl:border-l xl:border-t-0">
      <% if selected_post %>
        <div class="flex items-center justify-between">
          <p class="text-xs font-bold uppercase tracking-[0.16em] text-[color:var(--nd-muted)]">Selected expression</p>
          <%= link_to selected_post, class: "text-[color:var(--nd-muted)] hover:text-[color:var(--nd-accent)]", aria: { label: "표현 보기" }, title: "표현 보기" do %>
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 12s3.75-6.75 9.75-6.75S21.75 12 21.75 12 18 18.75 12 18.75 2.25 12 2.25 12z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          <% end %>
        </div>

        <div class="mt-6">
          <h2 class="nd-heading text-4xl font-semibold leading-tight text-[color:var(--nd-ink)]"><%= selected_post.title %></h2>
          <p class="mt-3 whitespace-pre-line text-sm leading-6 text-[color:var(--nd-ink)]"><%= truncate(selected_post.body.to_s, length: 180) %></p>
        </div>

        <dl class="mt-6 space-y-3 text-sm">
          <div class="flex items-center gap-3">
            <dt class="font-mono text-xs text-[color:var(--nd-muted)]">group</dt>
            <dd class="text-[color:var(--nd-ink)]"><%= selected_post.group&.name || "그룹 없음" %></dd>
          </div>
          <div class="flex items-center gap-3">
            <dt class="font-mono text-xs text-[color:var(--nd-muted)]">source</dt>
            <dd class="text-[color:var(--nd-ink)]"><%= selected_post.user.display_name %></dd>
          </div>
          <div class="flex items-center gap-3">
            <dt class="font-mono text-xs text-[color:var(--nd-muted)]">added</dt>
            <dd class="text-[color:var(--nd-ink)]"><%= l(selected_post.created_at, format: :short) %></dd>
          </div>
        </dl>

        <div class="mt-6 space-y-3">
          <p class="text-xs font-bold uppercase tracking-[0.14em] text-[color:var(--nd-muted)]">Memo / notes</p>
          <% if selected_post.comments.any? %>
            <% selected_post.comments.limit(2).each do |comment| %>
              <div class="rounded-lg bg-[#EED9A8] p-4">
                <p class="text-sm leading-6 text-[color:var(--nd-ink)]"><%= truncate(comment.body.to_s, length: 90) %></p>
              </div>
            <% end %>
          <% else %>
            <div class="rounded-lg bg-[#EED9A8] p-4">
              <p class="text-sm leading-6 text-[color:var(--nd-ink)]">아직 memo가 없습니다. 상세 화면에서 내 문장과 기억 단서를 남겨보세요.</p>
            </div>
          <% end %>
        </div>

        <%= link_to selected_post, class: "mt-6 inline-flex h-10 w-full items-center justify-center gap-2 rounded-md bg-[color:var(--nd-accent)] text-sm font-bold text-white hover:bg-[color:var(--nd-accent-strong)]" do %>
          memo 추가
        <% end %>
      <% else %>
        <div class="rounded-lg bg-[#EED9A8] p-4">
          <p class="text-xs font-bold uppercase tracking-[0.14em] text-[color:var(--nd-muted)]">Empty archive</p>
          <p class="mt-2 text-sm leading-6 text-[color:var(--nd-ink)]">새 표현을 만들면 이곳에 선택한 표현의 뜻과 memo가 표시됩니다.</p>
        </div>
      <% end %>
    </aside>
  </div>
</div>
