<% content_for :title, "항목 목록" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-6">
    <div>
      <h1 class="font-bold text-4xl">단어/용어장</h1>
      <p class="text-sm text-gray-500 mt-1">저장된 항목을 그룹과 검색으로 빠르게 찾아보세요.</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "새 항목 추가", new_post_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
      <%= link_to "그룹 관리", groups_path, class: "rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 text-gray-700 block font-medium" %>
    </div>
  </div>

  <div class="mb-6 rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
    <%= form_with url: posts_path, method: :get, class: "flex flex-col gap-3 md:flex-row" do |form| %>
      <%= form.text_field :query, value: params[:query], placeholder: "검색어 입력", class: "w-full rounded-md border border-gray-300 px-3 py-2" %>
      <%= form.select :group_id, options_from_collection_for_select(@groups, :id, :name, params[:group_id]), { include_blank: "전체 그룹" }, class: "rounded-md border border-gray-300 px-3 py-2" %>
      <%= form.submit "검색", class: "rounded-md bg-blue-600 px-4 py-2 text-white" %>
    <% end %>
  </div>

  <div id="posts" class="space-y-4">
    <% if @posts.any? %>
      <% @posts.each do |post| %>
        <div class="rounded-2xl border border-gray-200 bg-white px-5 py-4 shadow-sm transition hover:shadow-md">
          <h2 class="text-lg font-semibold text-gray-900 leading-tight">
            <%= link_to post.title, post_path(post), class: "hover:text-blue-600" %>
          </h2>
          <div class="mt-3 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2 text-sm text-gray-500">
            <div class="min-w-0 text-left">
              <span class="font-medium text-gray-700"><%= post.user.email %></span>
              <% if post.group.present? %>
                <span class="ml-2 rounded-full bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700"><%= post.group.name %></span>
              <% end %>
            </div>
            <div class="flex flex-wrap justify-start sm:justify-end items-center gap-2 text-sm text-gray-500">
              <span>조회: <%= post.views_count_for_display %></span>
              <span class="text-slate-300">•</span>
              <span>댓글: <%= post.comments.count %></span>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center py-10 text-gray-500">등록된 항목이 없습니다.</p>
    <% end %>
  </div>
</div>
