<% content_for :title, "Posts" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-6">
    <div>
      <h1 class="font-bold text-4xl">커뮤니티 글</h1>
      <p class="text-sm text-gray-500 mt-1">최근 게시글을 빠르게 확인하세요.</p>
    </div>
    <%= link_to "새 글 작성", new_post_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
  </div>

  <div id="posts" class="space-y-4">
    <% if @posts.any? %>
      <% @posts.each do |post| %>
        <div class="rounded-2xl border border-gray-200 bg-white px-5 py-4 shadow-sm transition hover:shadow-md">
          <h2 class="text-lg font-semibold text-gray-900 leading-tight">
            <%= link_to post.title, post_path(post), class: "hover:text-blue-600" %>
          </h2>
          <div class="mt-3 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2 text-sm text-gray-500">
            <div class="min-w-0 text-left">
              <span class="font-medium text-gray-700"><%= post.user.email %></span>
            </div>
            <div class="flex flex-wrap justify-start sm:justify-end items-center gap-2 text-sm text-gray-500">
              <span>조회: <%= post.views_count_for_display %></span>
              <span class="text-slate-300">•</span>
              <span>댓글: <%= post.comments.count %></span>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center py-10 text-gray-500">등록된 글이 없습니다.</p>
    <% end %>
  </div>
</div>
