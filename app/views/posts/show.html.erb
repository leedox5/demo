<% content_for :title, "항목 상세" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="mb-6 rounded-xl border border-[color:var(--nd-line)] bg-[color:var(--nd-surface)] px-6 py-5">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div class="space-y-2">
        <h2 class="nd-heading text-4xl font-semibold text-[color:var(--nd-ink)]"><%= @post.title %></h2>
        <div class="flex flex-wrap items-center gap-3 text-sm text-[color:var(--nd-muted)]">
          <span><%= @post.user.display_name %></span>
          <% if @post.group.present? %>
            <span class="rounded-full bg-[color:var(--nd-sidebar)] px-2 py-1 text-xs font-medium text-[color:var(--nd-accent)]"><%= @post.group.name %></span>
          <% end %>
          <span class="text-[color:var(--nd-line)]">•</span>
          <span><%= l(@post.created_at, format: :short) %></span>
          <span class="text-[color:var(--nd-line)]">•</span>
          <span>조회: <%= @post.views_count_for_display %></span>
        </div>
      </div>

      <div class="flex items-center gap-2">
        <%= link_to edit_post_path(@post), class: "inline-flex h-10 w-10 items-center justify-center rounded-md border border-[color:var(--nd-line)] bg-[color:var(--nd-surface)] text-[color:var(--nd-muted)] hover:bg-[color:var(--nd-sidebar)] hover:text-[color:var(--nd-accent)]", aria: { label: "항목 수정" }, title: "항목 수정" do %>
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4h2m-7 14h12M6 18l-1 3 3-1 8-8-2-2-8 8z" />
          </svg>
        <% end %>

        <%= link_to posts_path, class: "inline-flex h-10 w-10 items-center justify-center rounded-md border border-[color:var(--nd-line)] bg-[color:var(--nd-surface)] text-[color:var(--nd-muted)] hover:bg-[color:var(--nd-sidebar)] hover:text-[color:var(--nd-accent)]", aria: { label: "항목 목록으로" }, title: "항목 목록으로" do %>
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" />
          </svg>
        <% end %>

        <%= button_to @post, method: :delete, form_class: "inline-block", class: "inline-flex h-10 w-10 items-center justify-center rounded-md bg-[color:var(--nd-accent)] text-white hover:bg-[color:var(--nd-accent-strong)]", data: { turbo_confirm: "정말 삭제할까요?" }, aria: { label: "항목 삭제" }, title: "항목 삭제" do %>
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 7h12m-9 0V5h6v2m-7 0l1 12h4l1-12" />
          </svg>
        <% end %>
      </div>
    </div>

    <p class="mt-4 text-sm leading-6 text-[color:var(--nd-muted)]">
      Connecting the dots: 하나의 item에서 시작한 생각을 메모로 이어 붙이며 개념의 맥락을 확장해보세요.
    </p>
  </div>

  <%= render @post %>
</div>

<div class="w-full mt-10">
  <div class="rounded-xl border border-[color:var(--nd-line)] bg-[color:var(--nd-surface)] p-6">
    <div class="mb-4 flex items-center justify-between">
      <h2 class="nd-heading text-3xl font-semibold text-[color:var(--nd-ink)]">연결 노트</h2>
      <% if @comments.any? %>
        <span class="text-sm text-[color:var(--nd-muted)]"><%= @comments.size %>개 메모</span>
      <% end %>
    </div>

    <% if user_signed_in? %>
      <%= render "comments/form", post: @post, commentable_type: "Post", commentable_id: @post.id, submit_text: "메모 남기기" %>
    <% else %>
      <p class="text-sm text-[color:var(--nd-muted)]">메모 작성을 위해 <%= link_to "로그인", new_user_session_path, class: "text-[color:var(--nd-accent)] hover:underline" %> 해주세요.</p>
    <% end %>

    <div class="mt-8 space-y-4">
      <% if @comments.any? %>
        <%= render partial: "comments/comment", collection: @comments, as: :comment, locals: { post: @post } %>
      <% else %>
        <p class="text-[color:var(--nd-muted)]">아직 남겨진 메모가 없습니다.</p>
      <% end %>
    </div>
  </div>
</div>
