<% content_for :title, "항목 상세" %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="mb-6 rounded-xl border border-[color:var(--nd-line)] bg-[color:var(--nd-surface)] px-6 py-5">
    <div class="space-y-2">
      <h2 class="nd-heading text-4xl font-semibold text-[color:var(--nd-ink)]"><%= @post.title %></h2>
      <div class="flex flex-wrap items-center gap-3 text-sm text-[color:var(--nd-muted)]">
        <span><%= @post.user.display_name %></span>
        <% if @post.group.present? %>
          <span class="rounded-full bg-[color:var(--nd-sidebar)] px-2 py-1 text-xs font-medium text-[color:var(--nd-accent)]"><%= @post.group.name %></span>
        <% end %>
        <span class="text-[color:var(--nd-line)]">•</span>
        <span><%= l(@post.created_at, format: :short) %></span>
        <span class="text-[color:var(--nd-line)]">•</span>
        <span>조회: <%= @post.views_count_for_display %></span>
      </div>
    </div>
  </div>

  <%= render @post %>

  <div class="flex flex-col sm:flex-row gap-2 mt-6">
    <%= link_to "항목 수정", edit_post_path(@post), class: "w-full sm:w-auto text-center rounded-md border border-[color:var(--nd-line)] bg-[color:var(--nd-surface)] px-3.5 py-2.5 inline-block font-medium text-[color:var(--nd-ink)] hover:bg-[color:var(--nd-sidebar)]" %>
    <%= link_to "항목 목록으로", posts_path, class: "w-full sm:w-auto text-center rounded-md border border-[color:var(--nd-line)] bg-[color:var(--nd-surface)] px-3.5 py-2.5 inline-block font-medium text-[color:var(--nd-ink)] hover:bg-[color:var(--nd-sidebar)]" %>
    <%= button_to "항목 삭제", @post, method: :delete, form_class: "sm:inline-block", class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 text-white bg-[color:var(--nd-accent)] hover:bg-[color:var(--nd-accent-strong)] font-medium cursor-pointer", data: { turbo_confirm: "정말 삭제할까요?" } %>
  </div>
</div>

<div class="md:w-2/3 w-full mt-12">
  <div class="rounded-xl border border-[color:var(--nd-line)] bg-[color:var(--nd-surface)] p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="nd-heading text-3xl font-semibold text-[color:var(--nd-ink)]">댓글</h2>
      <% if @comments.any? %>
        <span class="text-sm text-[color:var(--nd-muted)]"><%= pluralize(@comments.size, "개") %> 등록됨</span>
      <% end %>
    </div>

    <% if user_signed_in? %>
      <%= render "comments/form", post: @post, commentable_type: "Post", commentable_id: @post.id, submit_text: "댓글 쓰기" %>
    <% else %>
      <p class="text-sm text-[color:var(--nd-muted)]">댓글 작성을 위해 <%= link_to "로그인", new_user_session_path, class: "text-[color:var(--nd-accent)] hover:underline" %> 해주세요.</p>
    <% end %>

    <div class="mt-8 space-y-4">
      <% if @comments.any? %>
        <%= render partial: "comments/comment", collection: @comments, as: :comment, locals: { post: @post } %>
      <% else %>
        <p class="text-[color:var(--nd-muted)]">아직 등록된 댓글이 없습니다.</p>
      <% end %>
    </div>
  </div>
</div>
