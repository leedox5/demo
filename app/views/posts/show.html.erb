<% content_for :title, "항목 상세" %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="mb-6 rounded-2xl border border-gray-200 bg-white px-6 py-5 shadow-sm">
    <div class="space-y-2">
      <h2 class="text-3xl font-semibold text-gray-900"><%= @post.title %></h2>
      <div class="flex flex-wrap items-center gap-3 text-sm text-gray-500">
        <span><%= @post.user.display_name %></span>
        <% if @post.group.present? %>
          <span class="rounded-full bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700"><%= @post.group.name %></span>
        <% end %>
        <span class="text-slate-300">•</span>
        <span><%= l(@post.created_at, format: :short) %></span>
        <span class="text-slate-300">•</span>
        <span>조회: <%= @post.views_count_for_display %></span>
      </div>
    </div>
  </div>

  <%= render @post %>

  <div class="flex flex-col sm:flex-row gap-2 mt-6">
    <%= link_to "항목 수정", edit_post_path(@post), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
    <%= link_to "항목 목록으로", posts_path, class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
    <%= button_to "항목 삭제", @post, method: :delete, form_class: "sm:inline-block", class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "정말 삭제할까요?" } %>
  </div>
</div>

<div class="md:w-2/3 w-full mt-12">
  <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-2xl font-semibold">댓글</h2>
      <% if @comments.any? %>
        <span class="text-sm text-gray-500"><%= pluralize(@comments.size, "개") %> 등록됨</span>
      <% end %>
    </div>

    <% if user_signed_in? %>
      <%= render "comments/form", post: @post, commentable_type: "Post", commentable_id: @post.id, submit_text: "댓글 쓰기" %>
    <% else %>
      <p class="text-sm text-gray-600">댓글 작성을 위해 <%= link_to "로그인", new_user_session_path, class: "text-blue-600 hover:underline" %> 해주세요.</p>
    <% end %>

    <div class="mt-8 space-y-4">
      <% if @comments.any? %>
        <%= render partial: "comments/comment", collection: @comments, as: :comment, locals: { post: @post } %>
      <% else %>
        <p class="text-gray-600">아직 등록된 댓글이 없습니다.</p>
      <% end %>
    </div>
  </div>
</div>
