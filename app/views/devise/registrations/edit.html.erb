<% content_for :title, "회원정보 수정" %>

<div class="mx-auto max-w-md rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
  <h2 class="mb-6 text-center text-2xl font-semibold text-gray-900">회원정보 수정</h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-4" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :name, "이름", class: "mb-1 block text-sm font-medium text-gray-700" %>
      <%= f.text_field :name, autofocus: true, autocomplete: "name", required: true, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none ring-0 focus:border-blue-500" %>
    </div>

    <div>
      <%= f.label :email, "이메일", class: "mb-1 block text-sm font-medium text-gray-700" %>
      <%= f.email_field :email, autocomplete: "email", class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none ring-0 focus:border-blue-500" %>
    </div>

    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <p class="rounded-md bg-blue-50 px-3 py-2 text-sm text-blue-700">확인 대기 중인 이메일: <%= resource.unconfirmed_email %></p>
    <% end %>

    <div>
      <%= f.label :password, "새 비밀번호", class: "mb-1 block text-sm font-medium text-gray-700" %>
      <p class="mb-2 text-xs text-gray-500">변경하지 않으려면 비워두세요.</p>
      <%= f.password_field :password, autocomplete: "new-password", class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-blue-500" %>
      <% if @minimum_password_length %>
        <p class="mt-1 text-xs text-gray-500">최소 <%= @minimum_password_length %>자 이상</p>
      <% end %>
    </div>

    <div>
      <%= f.label :password_confirmation, "새 비밀번호 확인", class: "mb-1 block text-sm font-medium text-gray-700" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-blue-500" %>
    </div>

    <div>
      <%= f.label :current_password, "현재 비밀번호", class: "mb-1 block text-sm font-medium text-gray-700" %>
      <p class="mb-2 text-xs text-gray-500">회원정보 변경을 위해 현재 비밀번호가 필요합니다.</p>
      <%= f.password_field :current_password, autocomplete: "current-password", class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-blue-500" %>
    </div>

    <div class="flex flex-col gap-2 sm:flex-row">
      <%= f.submit "저장하기", class: "w-full rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-blue-700" %>
      <%= link_to "돌아가기", :back, class: "w-full rounded-lg border border-gray-300 px-4 py-2.5 text-center text-sm font-semibold text-gray-700 hover:bg-gray-50" %>
    </div>
  <% end %>

  <div class="mt-8 border-t border-gray-200 pt-6">
    <h3 class="text-sm font-semibold text-gray-900">회원 탈퇴</h3>
    <p class="mt-1 text-sm text-gray-500">계정을 삭제하면 작성한 표현과 메모도 함께 삭제됩니다.</p>
    <%= button_to "계정 삭제", registration_path(resource_name), method: :delete, data: { turbo_confirm: "정말 계정을 삭제할까요?" }, class: "mt-3 rounded-lg bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-500" %>
  </div>
</div>
