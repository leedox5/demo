<div class="mx-auto flex min-h-[70vh] items-center justify-center px-4 py-10">
  <div class="w-full max-w-md rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
    <h2 class="mb-6 text-center text-2xl font-semibold text-gray-900">회원가입</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :name, "이름", class: "mb-1 block text-sm font-medium text-gray-700" %>
        <%= f.text_field :name, autofocus: true, autocomplete: "name", required: true, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none ring-0 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :email, "이메일", class: "mb-1 block text-sm font-medium text-gray-700" %>
        <%= f.email_field :email, autocomplete: "email", class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none ring-0 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :password, "비밀번호", class: "mb-1 block text-sm font-medium text-gray-700" %>
        <% if @minimum_password_length %>
          <p class="mb-2 text-xs text-gray-500">최소 <%= @minimum_password_length %>자 이상</p>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "비밀번호 확인", class: "mb-1 block text-sm font-medium text-gray-700" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-blue-500" %>
      </div>

      <div>
        <%= f.submit "가입하기", class: "w-full rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-blue-700" %>
      </div>
    <% end %>

    <div class="mt-6">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
