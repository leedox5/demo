<div class="mx-auto flex min-h-[70vh] items-center justify-center px-4 py-10">
  <div class="w-full max-w-md rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
    <h2 class="mb-2 text-center text-2xl font-semibold text-gray-900">비밀번호 찾기</h2>
    <p class="mb-6 text-center text-sm text-gray-500">가입한 이메일 주소를 입력하면 재설정 링크를 보내드립니다.</p>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-4" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "mb-1 block text-sm font-medium text-gray-700" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-blue-500" %>
      </div>

      <div>
        <%= f.submit "재설정 메일 보내기", class: "w-full rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-blue-700" %>
      </div>
    <% end %>

    <div class="mt-6">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
