<%- if controller_name != 'sessions' %>
  <p><%= link_to "로그인", new_session_path(resource_name), class: "text-sm font-medium text-blue-600 hover:text-blue-500" %></p>
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <p><%= link_to "회원가입", new_registration_path(resource_name), class: "text-sm font-medium text-blue-600 hover:text-blue-500" %></p>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <p><%= link_to "비밀번호를 잊으셨나요?", new_password_path(resource_name), class: "text-sm font-medium text-blue-600 hover:text-blue-500" %></p>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <p><%= link_to "인증 안내를 받지 못하셨나요?", new_confirmation_path(resource_name), class: "text-sm font-medium text-blue-600 hover:text-blue-500" %></p>
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <p><%= link_to "잠금 해제 안내를 받지 못하셨나요?", new_unlock_path(resource_name), class: "text-sm font-medium text-blue-600 hover:text-blue-500" %></p>
<% end %>

<%- if devise_mapping.omniauthable? %>
  <%- resource_class.omniauth_providers.each do |provider| %>
    <p><%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false } %></p>
  <% end %>
<% end %>
