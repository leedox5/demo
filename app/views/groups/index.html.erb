<% content_for :title, "Groups" %>

<div class="w-full">
  <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-semibold text-gray-900">그룹</h1>
      <p class="mt-1 text-sm text-gray-500">항목을 주제별로 정리해보세요.</p>
    </div>
    <%= link_to "새 그룹 만들기", new_group_path, class: "rounded-md bg-blue-600 px-3.5 py-2.5 text-white" %>
  </div>

  <% if @groups.any? %>
    <div class="grid gap-4 md:grid-cols-2">
      <% @groups.each do |group| %>
        <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h2 class="text-lg font-semibold text-gray-900"><%= link_to group.name, group_path(group), class: "hover:text-blue-600" %></h2>
              <p class="mt-2 text-sm text-gray-600"><%= group.description.presence || "설명 없음" %></p>
            </div>
            <div class="flex gap-2">
              <%= link_to "수정", edit_group_path(group), class: "text-sm font-medium text-blue-600" %>
              <%= button_to "삭제", group_path(group), method: :delete, form_class: "inline", class: "text-sm font-medium text-red-600", data: { turbo_confirm: "삭제할까요?" } %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-2xl border border-dashed border-gray-300 bg-white p-8 text-center text-gray-500">
      아직 그룹이 없습니다. 첫 그룹을 만들어보세요.
    </div>
  <% end %>
</div>
