<% content_for :title, @group.name %>
<% content_for :main_top_padding, "pt-4 sm:pt-5" %>

<div class="w-full">
  <div class="mb-6 rounded-xl border border-[color:var(--nd-line)] bg-[color:var(--nd-surface)] px-6 py-5">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.16em] text-[color:var(--nd-muted)]">Settings / Groups</p>
        <h1 class="mt-1 nd-heading text-4xl font-semibold text-[color:var(--nd-ink)]"><%= @group.name %></h1>
        <p class="mt-2 text-sm leading-6 text-[color:var(--nd-muted)]"><%= @group.description.presence || "그룹 설명이 없습니다." %></p>
      </div>

      <div class="flex items-center gap-2">
        <%= link_to groups_path, class: "inline-flex h-10 items-center gap-2 rounded-md border border-[color:var(--nd-line)] bg-[color:var(--nd-surface)] px-3 text-sm font-bold text-[color:var(--nd-ink)] hover:bg-[color:var(--nd-sidebar)]" do %>
          <svg class="h-4 w-4 text-[color:var(--nd-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          그룹 관리
        <% end %>
        <%= link_to edit_group_path(@group), class: "inline-flex h-10 items-center gap-2 rounded-md border border-[color:var(--nd-line)] bg-[color:var(--nd-surface)] px-3 text-sm font-bold text-[color:var(--nd-ink)] hover:bg-[color:var(--nd-sidebar)]" do %>
          <svg class="h-4 w-4 text-[color:var(--nd-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4h2m-7 14h12M6 18l-1 3 3-1 8-8-2-2-8 8z" />
          </svg>
          수정
        <% end %>
        <%= link_to new_post_path, class: "inline-flex h-10 items-center gap-2 rounded-md bg-[color:var(--nd-accent)] px-4 text-sm font-bold text-white hover:bg-[color:var(--nd-accent-strong)]" do %>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v14M5 12h14" />
          </svg>
          새 표현
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid gap-5 lg:grid-cols-[1fr_18rem]">
    <section class="space-y-4">
      <div class="flex items-center justify-between">
        <h2 class="nd-heading text-3xl font-semibold text-[color:var(--nd-ink)]">그룹 안의 표현</h2>
        <span class="text-sm text-[color:var(--nd-muted)]"><%= @posts.size %>개 표현</span>
      </div>

      <% if @posts.any? %>
        <div class="space-y-3">
          <% @posts.each do |post| %>
            <article class="rounded-lg border border-[color:var(--nd-line)] bg-[color:var(--nd-surface)] px-5 py-4 transition hover:border-[color:var(--nd-accent)]/50">
              <h3 class="nd-heading text-2xl font-semibold leading-tight text-[color:var(--nd-ink)]">
                <%= link_to post.title, post_path(post), class: "hover:text-[color:var(--nd-accent)]" %>
              </h3>
              <p class="mt-2 text-sm leading-6 text-[color:var(--nd-muted)]"><%= truncate(post.body.to_s, length: 150) %></p>
              <div class="mt-3 flex flex-wrap items-center gap-2 text-sm text-[color:var(--nd-muted)]">
                <span>조회: <%= post.views_count_for_display %></span>
                <span class="text-[color:var(--nd-line)]">•</span>
                <span><%= l(post.created_at, format: :short) %></span>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="rounded-xl border border-dashed border-[color:var(--nd-line)] bg-[color:var(--nd-surface)] px-6 py-10 text-center">
          <p class="nd-heading text-3xl font-semibold text-[color:var(--nd-ink)]">이 그룹에는 아직 표현이 없습니다.</p>
          <p class="mt-2 text-sm text-[color:var(--nd-muted)]">새 표현을 만들고 이 그룹에 연결해보세요.</p>
        </div>
      <% end %>
    </section>

    <aside class="rounded-xl border border-[color:var(--nd-line)] bg-[#FBF8ED] p-5">
      <p class="text-xs font-bold uppercase tracking-[0.16em] text-[color:var(--nd-muted)]">Group summary</p>
      <dl class="mt-5 space-y-3 text-sm">
        <div class="flex items-center justify-between gap-3">
          <dt class="font-mono text-xs text-[color:var(--nd-muted)]">expressions</dt>
          <dd class="font-bold text-[color:var(--nd-ink)]"><%= @posts.size %></dd>
        </div>
        <div class="flex items-center justify-between gap-3">
          <dt class="font-mono text-xs text-[color:var(--nd-muted)]">owner</dt>
          <dd class="font-bold text-[color:var(--nd-ink)]"><%= @group.user.display_name %></dd>
        </div>
        <div class="flex items-center justify-between gap-3">
          <dt class="font-mono text-xs text-[color:var(--nd-muted)]">updated</dt>
          <dd class="font-bold text-[color:var(--nd-ink)]"><%= l(@group.updated_at, format: :short) %></dd>
        </div>
      </dl>

      <div class="mt-6 rounded-lg bg-[#EED9A8] p-4">
        <p class="text-xs font-bold uppercase tracking-[0.14em] text-[color:var(--nd-muted)]">Safety</p>
        <p class="mt-2 text-sm leading-6 text-[color:var(--nd-ink)]">그룹 삭제 시 연결된 표현은 삭제되지 않고 그룹 없음으로 남습니다.</p>
      </div>

      <%= button_to group_path(@group), method: :delete, form_class: "mt-6", class: "inline-flex h-10 w-full items-center justify-center gap-2 rounded-md border border-red-600 bg-red-50 text-sm font-bold text-red-700 hover:bg-red-600 hover:text-white", data: { turbo_confirm: "그룹을 삭제할까요? 연결된 표현은 삭제되지 않고 그룹 없음으로 남습니다." } do %>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 7h12m-9 0V5h6v2m-7 0l1 12h4l1-12" />
        </svg>
        그룹 삭제
      <% end %>
    </aside>
  </div>
</div>
