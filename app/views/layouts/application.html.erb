<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "단어장" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="단어장">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 text-gray-900">
    <nav class="sticky top-0 z-50 border-b border-gray-200 bg-white/95 shadow-sm backdrop-blur-sm" data-controller="mobile-menu">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <%= link_to "LexiNote", root_path, class: "text-lg font-semibold text-blue-600" %>

        <button
          type="button"
          class="inline-flex items-center rounded-md p-2 text-gray-700 hover:bg-gray-100 hover:text-blue-600 md:hidden"
          aria-label="Toggle menu"
          data-action="mobile-menu#toggle"
          data-mobile-menu-target="button"
        >
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>

        <div class="hidden items-center gap-4 text-sm font-medium text-gray-700 md:flex">
          <%= link_to "홈", root_path, class: "hover:text-blue-600" %>
          <%= link_to "항목", posts_path, class: "hover:text-blue-600" %>
          <%= link_to "그룹", groups_path, class: "hover:text-blue-600" %>
          <% if user_signed_in? %>
            <%= link_to current_user.display_name, edit_user_registration_path, class: "text-gray-500 hover:text-blue-600" %>
            <%= button_to "로그아웃", destroy_user_session_path, method: :delete, class: "hover:text-blue-600" %>
          <% else %>
            <%= link_to "로그인", new_user_session_path, class: "hover:text-blue-600" %>
            <%= link_to "회원가입", new_user_registration_path, class: "hover:text-blue-600" %>
          <% end %>
        </div>
      </div>

      <div id="mobile-menu" class="hidden border-t border-gray-200 bg-white px-6 py-3 md:hidden" data-mobile-menu-target="menu">
        <div class="flex flex-col gap-2 text-sm font-medium text-gray-700" data-action="click->mobile-menu#close">
          <%= link_to "홈", root_path, class: "rounded px-2 py-1 hover:bg-gray-100 hover:text-blue-600" %>
          <%= link_to "항목", posts_path, class: "rounded px-2 py-1 hover:bg-gray-100 hover:text-blue-600" %>
          <%= link_to "그룹", groups_path, class: "rounded px-2 py-1 hover:bg-gray-100 hover:text-blue-600" %>
          <% if user_signed_in? %>
            <%= link_to current_user.display_name, edit_user_registration_path, class: "rounded px-2 py-1 text-gray-500 hover:bg-gray-100 hover:text-blue-600" %>
            <%= button_to "로그아웃", destroy_user_session_path, method: :delete, class: "rounded px-2 py-1 text-left hover:bg-gray-100 hover:text-blue-600" %>
          <% else %>
            <%= link_to "로그인", new_user_session_path, class: "rounded px-2 py-1 hover:bg-gray-100 hover:text-blue-600" %>
            <%= link_to "회원가입", new_user_registration_path, class: "rounded px-2 py-1 hover:bg-gray-100 hover:text-blue-600" %>
          <% end %>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="mx-auto mt-4 max-w-6xl rounded bg-green-100 px-4 py-3 text-sm text-green-800"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div class="mx-auto mt-2 max-w-6xl rounded bg-red-100 px-4 py-3 text-sm text-red-800"><%= alert %></div>
    <% end %>

    <% main_top_padding = content_for?(:main_top_padding) ? yield(:main_top_padding) : "pt-5" %>
    <% main_x_padding = content_for?(:main_x_padding) ? yield(:main_x_padding) : "px-6" %>
    <main class="mx-auto max-w-6xl <%= main_x_padding %> <%= main_top_padding %> pb-10">
      <%= yield %>
    </main>
  </body>
</html>
