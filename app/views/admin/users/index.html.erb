<% content_for :title, "사용자 관리" %>

<div class="w-full">
  <div class="mb-6 flex items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">사용자 관리</h1>
      <p class="mt-1 text-sm text-gray-500">가입 사용자 목록과 관리자 권한 상태를 확인할 수 있습니다.</p>
    </div>
  </div>

  <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-600">이름</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-600">이메일</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-600">가입일</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-600">권한</th>
          <th scope="col" class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-600">관리 작업</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 bg-white">
        <% @users.each do |user| %>
          <tr>
            <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= user.display_name %></td>
            <td class="px-4 py-3 text-sm text-gray-700"><%= user.email %></td>
            <td class="px-4 py-3 text-sm text-gray-600"><%= l(user.created_at, format: :short) %></td>
            <td class="px-4 py-3 text-sm">
              <% if user.is_admin? %>
                <span class="inline-flex rounded-full bg-blue-50 px-2.5 py-1 text-xs font-semibold text-blue-700">관리자</span>
              <% else %>
                <span class="inline-flex rounded-full bg-gray-100 px-2.5 py-1 text-xs font-semibold text-gray-600">일반</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-right text-sm">
              <% if user.is_admin? %>
                <%= button_to "관리자 해제",
                  admin_user_path(user, is_admin: false),
                  method: :patch,
                  class: "inline-flex rounded-md border border-gray-300 px-3 py-1.5 font-medium text-gray-700 hover:bg-gray-50",
                  form: { data: { turbo_confirm: "#{user.display_name}님의 관리자 권한을 해제할까요?" } } %>
              <% else %>
                <%= button_to "관리자 지정",
                  admin_user_path(user, is_admin: true),
                  method: :patch,
                  class: "inline-flex rounded-md bg-blue-600 px-3 py-1.5 font-medium text-white hover:bg-blue-500",
                  form: { data: { turbo_confirm: "#{user.display_name}님을 관리자로 지정할까요?" } } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
